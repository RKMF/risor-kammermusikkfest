{
  "name": "studio",
  "private": true,
  "version": "1.0.0",
  "main": "package.json",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=24.16.0 <25",
    "npm": ">=11.17.0 <12"
  },
  "scripts": {
    "predev": "node ../scripts/link-studio-hoisted-deps.mjs",
    "dev": "./node_modules/.bin/sanity dev --port 3333",
    "predev:typegen": "node ../scripts/link-studio-hoisted-deps.mjs",
    "dev:typegen": "SANITY_STUDIO_WRITE_GENERATED_ARTIFACTS=true ./node_modules/.bin/sanity dev --port 3333",
    "prestart": "node ../scripts/link-studio-hoisted-deps.mjs",
    "start": "./node_modules/.bin/sanity start",
    "prebuild": "node ../scripts/link-studio-hoisted-deps.mjs",
    "build": "./node_modules/.bin/sanity build",
    "predeploy": "node ../scripts/link-studio-hoisted-deps.mjs",
    "deploy": "./node_modules/.bin/sanity deploy",
    "deploy-graphql": "./node_modules/.bin/sanity graphql deploy",
    "extract-schema": "./node_modules/.bin/sanity schema extract",
    "pretypegen": "node ../scripts/link-studio-hoisted-deps.mjs",
    "typegen": "./node_modules/.bin/sanity schema extract && ./node_modules/.bin/sanity typegen generate",
    "test": "vitest",
    "test:watch": "vitest --watch"
  },
  "keywords": [
    "sanity"
  ],
  "dependencies": {
    "@codemirror/commands": "6.10.3",
    "@codemirror/language": "6.12.3",
    "@codemirror/search": "6.7.0",
    "@codemirror/state": "6.6.0",
    "@codemirror/view": "6.43.0",
    "@lezer/highlight": "^1.2.3",
    "@sanity/locale-nb-no": "1.1.34",
    "@sanity/vision": "6.0.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-is": "19.2.7",
    "sanity": "6.0.0",
    "sanity-plugin-asset-source-unsplash": "7.0.8",
    "styled-components": "6.4.2"
  },
  "devDependencies": {
    "@sanity/eslint-config-studio": "^5.0.2",
    "eslint": "9.39.4",
    "prettier": "3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "5.9.3",
    "vitest": "4.1.8"
  }
}

#!/bin/bash

RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m'

echo -e "${GREEN}🔍 Running pre-commit security checks...${NC}"

echo -e "${YELLOW}→ Checking for .env files...${NC}"

ENV_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.env$|\.env\.[^e]')

if [ ! -z "$ENV_FILES" ]; then
    echo -e "${RED}❌ ERROR: Attempting to commit .env files!${NC}"
    echo -e "${RED}The following files contain environment variables and should NOT be committed:${NC}"
    echo "$ENV_FILES" | while read file; do
        echo -e "${RED}  - $file${NC}"
    done
    echo ""
    echo -e "${YELLOW}💡 Only .env.example should be committed.${NC}"
    echo -e "${YELLOW}To fix: git restore --staged <filename>${NC}"
    echo ""
    exit 1
fi

echo -e "${YELLOW}→ Scanning for API keys and tokens...${NC}"

PATTERNS=(
    "SANITY_AUTH_TOKEN.*=.*[a-zA-Z0-9]{20,}"
    "SANITY_API_READ_TOKEN.*=.*sk[a-zA-Z0-9]{20,}"
    "API_KEY.*=.*[a-zA-Z0-9]{20,}"
    "SECRET.*=.*[a-zA-Z0-9]{20,}"
    "PASSWORD.*=.*[a-zA-Z0-9]{8,}"
    "sk_live_[a-zA-Z0-9]+"
    "pk_live_[a-zA-Z0-9]+"
    "sk_test_[a-zA-Z0-9]+"
    "pk_test_[a-zA-Z0-9]+"
    "BEGIN.*PRIVATE KEY"
    "BEGIN RSA PRIVATE KEY"
)

SECRETS_FOUND=0

for PATTERN in "${PATTERNS[@]}"; do
    MATCHES=$(git diff --cached -- . ':(exclude).githooks/pre-commit' | grep -E "$PATTERN" | grep -v "your_.*_here" | grep -v "example" | grep -v "placeholder")

    if [ ! -z "$MATCHES" ]; then
        if [ $SECRETS_FOUND -eq 0 ]; then
            echo -e "${RED}❌ ERROR: Potential secrets detected in staged changes!${NC}"
            echo ""
        fi
        echo -e "${RED}Pattern found: $PATTERN${NC}"
        echo "$MATCHES" | head -3
        echo ""
        SECRETS_FOUND=1
    fi
done

if [ $SECRETS_FOUND -eq 1 ]; then
    echo -e "${YELLOW}💡 Tips:${NC}"
    echo -e "${YELLOW}  1. Use environment variables instead of hardcoded secrets${NC}"
    echo -e "${YELLOW}  2. Add secrets to .env file (already in .gitignore)${NC}"
    echo -e "${YELLOW}  3. Use placeholders like 'your_token_here' in .env.example${NC}"
    echo ""
    echo -e "${YELLOW}To bypass this check (ONLY if false positive): git commit --no-verify${NC}"
    echo ""
    exit 1
fi

echo -e "${YELLOW}→ Checking for large files...${NC}"

LARGE_FILES=$(git diff --cached --name-only --diff-filter=ACM | while read file; do
    [ "$file" = "package-lock.json" ] && continue
    SIZE=$(du -k "$file" 2>/dev/null | cut -f1)
    if [ ! -z "$SIZE" ] && [ $SIZE -gt 500 ]; then
        echo "$file ($SIZE KB)"
    fi
done)

if [ ! -z "$LARGE_FILES" ]; then
    echo -e "${YELLOW}⚠️  WARNING: Large files detected:${NC}"
    echo "$LARGE_FILES" | while read file; do
        echo -e "${YELLOW}  - $file${NC}"
    done
    echo -e "${YELLOW}Consider if these should be committed or added to .gitignore${NC}"
    echo ""
fi

echo -e "${YELLOW}→ Checking for node_modules...${NC}"

NODE_MODULES=$(git diff --cached --name-only --diff-filter=ACM | grep "node_modules/")

if [ ! -z "$NODE_MODULES" ]; then
    echo -e "${RED}❌ ERROR: Attempting to commit node_modules!${NC}"
    echo -e "${RED}node_modules should NEVER be committed.${NC}"
    echo ""
    echo -e "${YELLOW}To fix:${NC}"
    echo -e "${YELLOW}  git restore --staged node_modules${NC}"
    echo -e "${YELLOW}  Ensure node_modules/ is in .gitignore${NC}"
    echo ""
    exit 1
fi

echo -e "${GREEN}✅ All security checks passed!${NC}"
echo -e "${GREEN}Proceeding with commit...${NC}"
echo ""

exit 0

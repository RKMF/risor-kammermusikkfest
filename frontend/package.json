{
  "name": "frontend",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=24.16.0 <25"
  },
  "scripts": {
    "dev": "astro dev --port 4321",
    "build": "npm run typecheck && astro build",
    "typecheck": "npx -p typescript@5.9.3 tsc --noEmit",
    "preview": "astro preview",
    "astro": "astro",
    "check:htmx": "node ./scripts/check-htmx.mjs",
    "sync:htmx": "node ./scripts/sync-htmx.mjs",
    "typegen": "echo 'Run npm run typegen from the monorepo root instead' && exit 1",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage"
  },
  "dependencies": {
    "@astrojs/check": "0.9.9",
    "@astrojs/react": "5.0.7",
    "@astrojs/sitemap": "3.7.3",
    "@astrojs/vercel": "10.0.8",
    "@portabletext/types": "4.0.2",
    "@sanity/client": "7.22.1",
    "groq": "^4.22.0",
    "@sanity/image-url": "^2.0.2",
    "@vercel/analytics": "1.6.1",
    "@vercel/speed-insights": "1.3.1",
    "astro": "6.4.4",
    "astro-portabletext": "0.13.0",
    "htmx.org": "2.0.10",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-is": "19.2.7",
    "styled-components": "6.4.2"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@vitest/ui": "4.1.8",
    "typescript": "5.9.3",
    "vitest": "4.1.8"
  }
}

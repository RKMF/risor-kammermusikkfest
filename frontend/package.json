{
  "name": "frontend",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "astro dev --port 4321",
    "build": "npm run typecheck && astro build",
    "typecheck": "npx -p typescript tsc --noEmit",
    "preview": "astro preview",
    "astro": "astro",
    "typegen": "echo 'Run npm run typegen from the monorepo root instead' && exit 1",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage"
  },
  "dependencies": {
    "@astrojs/check": "0.9.8",
    "@astrojs/react": "5.0.3",
    "@astrojs/sitemap": "3.7.2",
    "@astrojs/vercel": "10.0.4",
    "@portabletext/types": "4.0.0",
    "@sanity/client": "^7.13.2",
    "groq": "^4.22.0",
    "@sanity/image-url": "^2.0.2",
    "@vercel/analytics": "1.6.1",
    "@vercel/speed-insights": "1.3.1",
    "astro": "6.1.5",
    "astro-portabletext": "0.13.0",
    "htmx.org": "^2.0.8",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-is": "^19.2.3",
    "styled-components": "^6.1.19"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@vitest/ui": "^4.0.16",
    "happy-dom": "20.0.11",
    "typescript": "5.9.3",
    "vitest": "^4.0.16"
  }
}

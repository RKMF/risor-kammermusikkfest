---
import ContentPageLayout from '../layouts/ContentPageLayout.astro';
import ProgramFilters from '../components/ProgramFilters.astro';
import EventCard from '../components/EventCard.astro';
import ScrollNavigation from '../components/ScrollNavigation.astro';
import FestivalSchema from '../components/structured-data/FestivalSchema.astro';
import { createDataService } from '../lib/sanity/dataService.js';
import { formatDateWithWeekday } from '../lib/utils/dates';
import { compareEventChronologicallyAsc } from '../lib/utils/eventOrdering';
import { deriveAvailableVenues } from '../lib/utils/programFilters';
import {
  applyProgramFilters,
  buildProgramEmptyStateMessage,
  buildProgramFilterPath,
  getValidatedSelectedDates,
  getValidatedSelectedVenues,
} from '../lib/utils/programFilterState';
import { stegaClean } from '@sanity/client/stega';
import '../styles/program.css';
import '../styles/event-card-collection.css';

interface Props {
  language: 'no' | 'en';
}

const { language } = Astro.props;

// Language-specific paths
const basePath = language === 'no' ? '/program' : '/en/program';

// Shared data service for language-aware Sanity reads
const dataService = createDataService(Astro.request);

// Clear cache in development to ensure fresh data
if (import.meta.env.DEV) {
  dataService.clearCache();
}

// Fetch program page content
const programPage = await dataService.getProgramPage();

// Get events from programPage.selectedEvents and filter out null/undefined
const events = (programPage?.selectedEvents || []).filter(event => event != null);

// Fallback values
const pageTitle = programPage?.title || 'Program';

// Extract unique dates for filter
const availableDates = events
  .filter(event => event.eventDate?.date)
  .map(event => ({
    date: event.eventDate!.date,
    title: event.eventDate!.title
  }));

// Extract unique venues for filter (preserve Sanity order)
const availableVenues = deriveAvailableVenues(events, programPage?.venueFilterOrder || []);

// Group events by date
const eventsByDate = events.reduce((acc, event) => {
  if (!event?.eventDate?.date) return acc;

  const dateKey = event.eventDate.date;
  if (!acc[dateKey]) {
    acc[dateKey] = {
      date: event.eventDate.date,
      displayTitle: event.eventDate.title || formatDateWithWeekday(event.eventDate.date, language),
      events: []
    };
  }
  acc[dateKey].events.push(event);
  return acc;
}, {} as Record<string, { date: string; displayTitle: string; events: typeof events }>);

// Sort dates chronologically and sort events within each date by time
const sortedDates = Object.values(eventsByDate)
  .sort((a, b) => new Date(a.date).getTime() - new Date(b.date).getTime())
  .map(dateGroup => ({
    ...dateGroup,
    events: [...dateGroup.events].sort(compareEventChronologicallyAsc)
  }));

const selectedDates = getValidatedSelectedDates(Astro.url.searchParams);
const selectedVenues = getValidatedSelectedVenues(Astro.url.searchParams);
const selections = { selectedDates, selectedVenues };
const hasActiveFilters = selectedDates.length > 0 || selectedVenues.length > 0;
const resolvedSeo = hasActiveFilters
  ? {
      ...(programPage?.seo || {}),
      indexingStatus: 'noindex' as const
    }
  : programPage?.seo;

function buildFilterUrl(dates: string[], venues: string[]) {
  return buildProgramFilterPath('/api/filter-program', dates, venues, language);
}

const filteredDates = applyProgramFilters(sortedDates, selections);

// Check if we have any events after filtering
const hasEvents = filteredDates.length > 0 && filteredDates.some(d => d.events.length > 0);

// Build contextual message for empty state
const emptyStateMessage = buildProgramEmptyStateMessage(
  selections,
  availableDates,
  availableVenues,
  language
);

// Language-specific UI strings
const emptyStateHint = language === 'no' ? 'Prøv en annen kombinasjon, eller:' : 'Choose a different combination, or:';
const resetButtonText = language === 'no' ? 'Nullstill filtre' : 'Reset filters';
---

<ContentPageLayout
  title={pageTitle}
  excerpt={programPage?.excerpt}
  pageDocument={programPage}
  seo={resolvedSeo}
>
  <!-- Structured Data: Festival Schema for Program Page -->
  <FestivalSchema programPage={programPage} events={events} lang={language} slot="structured-data" />

  <div id="program-content">
    <ProgramFilters
      availableDates={availableDates}
      availableVenues={availableVenues}
      language={language}
    />

    <div id="event-results">
      {hasEvents ? (
        filteredDates.map(({ date, displayTitle, events: dateEvents }) => (
        <section class="content-section date-section" data-date={date}>
          <h2 class="date-title">{stegaClean(displayTitle)}</h2>
          <div class="scroll-container-wrapper" data-scroll-step="item">
            <div
              class="event-card-collection scroll-container scroll-container--event-cards scroll-container--styled-scrollbar"
              role="region"
              tabindex="0"
              aria-label={language === 'no' ? 'Arrangementer' : 'Events'}
            >
              {dateEvents.map((event) => (
                <EventCard event={event} language={language} />
              ))}
            </div>
          </div>
          <ScrollNavigation size="medium" ariaLabel={language === 'no' ? 'Bla gjennom arrangementer' : 'Scroll through events'} />
        </section>
      ))
    ) : (
      <section class="content-section">
        <div class="no-results">
          <h3 class="no-results-title">{emptyStateMessage}</h3>
          <p class="no-results-text">{emptyStateHint}</p>
          <a
            href={basePath}
            rel="nofollow"
            class="link-button"
            data-filter-type="reset"
            data-filter-value=""
            hx-get={buildFilterUrl([], [])}
            hx-target="#event-results"
            hx-swap="innerHTML show:none"
            hx-push-url="true"
            hx-indicator="#filter-loading"
          >
            {resetButtonText}
          </a>
        </div>
      </section>
      )}
    </div>
  </div>
</ContentPageLayout>

<script>
  import { initializeFilterButtonStateSynchronization } from '../scripts/syncFilterButtonStatesWithUrl.js';

  // Initialize filter button state sync on page load
  initializeFilterButtonStateSynchronization();
</script>

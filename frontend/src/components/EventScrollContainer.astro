---
import { sanityClient } from "../lib/sanity/client";
import { createMultilingualField, detectLanguage } from "../lib/utils/language.js";
import { sortEventsByMode } from '../lib/utils/eventOrdering';
import EventCard from './EventCard.astro';
import ScrollNavigation from './ScrollNavigation.astro';
import type { EventResult } from '../lib/sanity/queries';
import '../styles/event-card-collection.css';

interface Props {
  title?: string
  items?: EventResult[]
  events?: any[]
  showScrollbar?: boolean
  sortBy?: 'date-asc' | 'date-desc' | 'title-asc' | 'manual'
}

const {
  title,
  items = [],
  events,
  showScrollbar = false,
  sortBy = 'date-asc'
} = Astro.props

const incomingItems = (events ?? items).filter(Boolean) as Array<EventResult & { _ref?: string }>
const itemOrder = new Map(
  incomingItems
    .map((item, index) => [item?._ref ?? item?._id, index] as const)
    .filter(([itemId]) => Boolean(itemId))
)
const eventRefs = incomingItems
  .filter((item) => item?._ref)
  .map((item) => item._ref as string)

// Top-level page queries provide full objects. Nested content can still send
// raw references, so fall back to the legacy narrow fetch only in that case.
let eventItems = incomingItems.filter((item) => !item._ref) as EventResult[]

// Detect current language from URL
const currentLanguage = detectLanguage(Astro.request)
const eventDateTitleField = currentLanguage === 'en'
  ? '"title": coalesce(title_display_en, title_display_no, title_display)'
  : '"title": coalesce(title_display_no, title_display_en, title_display)'
const showingTicketInfoField = currentLanguage === 'en'
  ? '"ticketInfoText": coalesce(ticketInfoText_en, ticketInfoText_no, ticketInfoText)'
  : '"ticketInfoText": coalesce(ticketInfoText_no, ticketInfoText_en, ticketInfoText)'

if (eventRefs.length > 0) {
  const EVENT_QUERY = `*[_type == "event" && _id in $eventIds]{
    _id,
    _type,
    title_no,
    title_en,
    ${createMultilingualField('title', currentLanguage)},
    slug_no,
    slug_en,
    "slug": coalesce(slug_no.current, slug_en.current, slug.current),
    excerpt_no,
    excerpt_en,
    ${createMultilingualField('excerpt', currentLanguage)},
    "image": {
      "image": image{
        asset->{
          _id,
          url,
          metadata {
            dimensions {
              width,
              height,
              aspectRatio
            },
            lqip,
            palette {
              dominant {
                background,
                foreground
              }
            }
          }
        },
        hotspot,
        crop
      },
      "alt": coalesce(imageAlt_no, imageAlt_en, image.alt),
      "credit": coalesce(imageCredit_no, imageCredit_en)
    },
    showings[]{
      _key,
      eventDate->{
        _id,
        date,
        title_display_no,
        title_display_en,
        ${eventDateTitleField}
      },
      startTime,
      endTime,
      "venue": select(
        defined(venueDetails.mode) && venueDetails.mode == "reference" && defined(venueDetails.venueRef) => venueDetails.venueRef->{
          _id,
          title,
          name,
          address,
          city,
          "slug": slug.current
        },
        defined(venueDetails.mode) && venueDetails.mode == "custom" && defined(venueDetails.customName) => {
          "title": venueDetails.customName
        },
        defined(venue) => venue->{
          _id,
          title,
          name,
          address,
          city,
          "slug": slug.current
        },
        null
      ),
      "includeInProgramVenueFilter": select(
        defined(venueDetails.mode) && venueDetails.mode == "reference" => coalesce(venueDetails.includeInProgramVenueFilter, true),
        defined(venueDetails.mode) && venueDetails.mode == "custom" => false,
        defined(includeInProgramVenueFilter) => includeInProgramVenueFilter,
        true
      ),
      ticketType,
      ticketUrl,
      ticketInfoText_no,
      ticketInfoText_en,
      ${showingTicketInfoField},
      ticketStatus
    },
    occurrences[]{
      _key,
      eventDate->{
        _id,
        date,
        title_display_no,
        title_display_en,
        ${eventDateTitleField}
      },
      showings[]{
        _key,
        startTime,
        endTime,
        "venue": select(
          defined(venueMode) && venueMode == "reference" && defined(venueRef) => venueRef->{
            _id,
            title,
            name,
            address,
            city,
            "slug": slug.current
          },
          defined(venueMode) && venueMode == "custom" && defined(customVenueName) => {
            "title": customVenueName
          },
          defined(venueDetails.mode) && venueDetails.mode == "reference" && defined(venueDetails.venueRef) => venueDetails.venueRef->{
            _id,
            title,
            name,
            address,
            city,
            "slug": slug.current
          },
          defined(venueDetails.mode) && venueDetails.mode == "custom" && defined(venueDetails.customName) => {
            "title": venueDetails.customName
          },
          defined(venue) => venue->{
            _id,
            title,
            name,
            address,
            city,
            "slug": slug.current
          },
          null
        ),
        "includeInProgramVenueFilter": select(
          defined(venueMode) && venueMode == "reference" => coalesce(includeInProgramVenueFilter, true),
          defined(venueMode) && venueMode == "custom" => false,
          defined(venueDetails.mode) && venueDetails.mode == "reference" => coalesce(venueDetails.includeInProgramVenueFilter, true),
          defined(venueDetails.mode) && venueDetails.mode == "custom" => false,
          defined(includeInProgramVenueFilter) => includeInProgramVenueFilter,
          true
        ),
        ticketType,
        ticketUrl,
        ticketInfoText_no,
        ticketInfoText_en,
        ${showingTicketInfoField},
        ticketStatus
      }
    },
    eventDate->{
      _id,
      date,
      title_display_no,
      title_display_en,
      ${eventDateTitleField}
    },
    eventTime,
    venue->{
      _id,
      title,
      name,
      address,
      city,
      "slug": slug.current
    },
    ticketType,
    ticketUrl,
    ticketInfoText,
    ticketStatus,
    eventDateValue,
    eventStartTimeValue,
    publishingStatus,
    scheduledPeriod,
    seo
  }`
  eventItems = await sanityClient.fetch(EVENT_QUERY, { eventIds: eventRefs })
  eventItems.sort((a, b) => (itemOrder.get(a._id) ?? Infinity) - (itemOrder.get(b._id) ?? Infinity))
}
const programIndexLink = currentLanguage === 'no'
  ? { href: '/program', text: 'Se hele programmet' }
  : { href: '/en/program', text: 'See the full program' }

// Sort events based on selected sort option
let sortedEvents = [...eventItems]
switch (sortBy) {
  case 'date-asc':
    sortedEvents = sortEventsByMode(eventItems, 'date-asc')
    break
  case 'date-desc':
    sortedEvents = sortEventsByMode(eventItems, 'date-desc')
    break
  case 'title-asc':
    sortedEvents = sortEventsByMode(eventItems, 'title-asc')
    break
  case 'manual':
  default:
    sortedEvents = [...eventItems]
    break
}

// CSS classes based on props
const containerClass = 'event-scroll-container'
const scrollbarClass = showScrollbar ? '' : 'hide-scrollbar'
---

<section class={`${containerClass} ${scrollbarClass}`}>
  <div class="event-scroll-header scroll-section-header">
    {title && <h2 class="event-scroll-title">{title}</h2>}
    <a href={programIndexLink.href} class="event-scroll-link scroll-section-link hover-underline">{programIndexLink.text} →</a>
  </div>
  <div class="scroll-container-wrapper" data-scroll-step="item">
    <ul
      class="event-list event-card-collection scroll-container scroll-container--always scroll-container--event-cards scroll-container--styled-scrollbar"
      tabindex="0"
      aria-label={currentLanguage === 'no' ? 'Arrangementer' : 'Events'}
    >
      {sortedEvents.map((event) => {
          if (!event) return null

          return (
            <li class="event-item">
              <EventCard event={event} language={currentLanguage} />
            </li>
          )
        })}
    </ul>
  </div>
  <ScrollNavigation size="medium" ariaLabel={currentLanguage === 'no' ? 'Bla gjennom arrangementer' : 'Scroll through events'} />
</section>

<style>
  /* Scroll Container */
  .event-scroll-container {
    container-type: inline-size;
    width: min(100ch, 100% - 4rem);
    margin-inline: auto;
    margin-block: var(--space-m-l); /* Fluid 16px → 30px */
  }

  .event-scroll-title {
    font-size: var(--step-3);
    font-weight: 600;
    margin: 0;
  }

  .event-scroll-header {
    margin-block-end: var(--space-m);
  }

  /* Scroll list - behavior from scroll-containers.css */
  .event-list {
    list-style: none;
    margin: 0;
    padding-block: var(--space-2);
  }

  .event-item {
    /* Container for EventCard component */
    display: contents;
  }

  /* Hide scrollbar on touch devices only (mouse users need scrollbar) */
  @media (pointer: coarse) {
    .hide-scrollbar .event-list.scroll-container {
      scrollbar-width: none;
      -ms-overflow-style: none;
      padding-block-end: 0;
    }

    .hide-scrollbar .event-list.scroll-container::-webkit-scrollbar {
      display: none;
    }
  }

  /* Support for reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .event-list.scroll-container {
      scroll-behavior: auto;
    }
  }

</style>

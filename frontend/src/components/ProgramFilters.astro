---
/**
 * ProgramFilters - HTMX-powered date and venue filter controls
 *
 * Renders filter buttons for the program page. Uses HTMX for instant filtering
 * without full page reload, with progressive enhancement (href fallback works
 * without JavaScript).
 *
 * HTMX integration:
 * - hx-get: Fetches filtered results from /api/filter-program
 * - hx-target: Updates #event-results container
 * - hx-push-url: Updates browser URL for bookmarkable/shareable filter state
 * - hx-indicator: Shows loading state during request
 *
 * Filter state is synced with URL parameters (date=, venue=) for:
 * - Shareable filtered views
 * - Browser back/forward navigation
 * - Bookmarkable filter combinations
 *
 * @see src/scripts/syncFilterButtonStatesWithUrl.js - Client-side state sync
 * @see src/pages/api/filter-program.ts - Server-side filter endpoint
 */

import {
  buildProgramFilterRenderState,
  getValidatedSelectedDates,
  getValidatedSelectedVenues,
} from '../lib/utils/programFilterState';

interface Props {
  /** Available event dates for date filter buttons */
  availableDates: Array<{ date: string; title?: string }>;
  /** Available venues for venue filter buttons */
  availableVenues: Array<{ slug: string; title: string }>;
  /** Display language for labels */
  language: 'no' | 'en';
}

const { availableDates, availableVenues, language } = Astro.props;

// Extract unique dates from events and sort
const currentDates = getValidatedSelectedDates(Astro.url.searchParams);
const currentVenues = getValidatedSelectedVenues(Astro.url.searchParams);
const filterState = buildProgramFilterRenderState(
  availableDates,
  availableVenues,
  { selectedDates: currentDates, selectedVenues: currentVenues },
  language
);
---

<section id="filter-container" role="search" aria-label={language === 'no' ? 'Filter arrangementer' : 'Filter events'}>
  <!-- DATE FILTER SECTION -->
  {filterState.dateButtons.length > 0 && (
    <div class="date-filter">
      <div
        class="date-filter-buttons"
        role="region"
        tabindex="0"
        aria-label={language === 'no' ? 'Filtrer etter dato' : 'Filter by date'}
      >
        <a
          href={filterState.allDatesButton.pageHref}
          rel="nofollow"
          class:list={['link-button', { active: filterState.allDatesButton.isActive }]}
          aria-pressed={filterState.allDatesButton.isActive}
          data-filter-type="date"
          data-filter-value={filterState.allDatesButton.value}
          hx-get={filterState.allDatesButton.apiHref}
          hx-target="#event-results"
          hx-swap="innerHTML show:none"
          hx-push-url="true"
          hx-indicator="#filter-loading"
        >
          {filterState.allDatesButton.label}
        </a>

        {filterState.dateButtons.map((button) => (
            <a
              href={button.pageHref}
              rel="nofollow"
              class:list={['link-button', { active: button.isActive }]}
              aria-pressed={button.isActive}
              data-filter-type="date"
              data-filter-value={button.value}
              hx-get={button.apiHref}
              hx-target="#event-results"
              hx-swap="innerHTML show:none"
              hx-push-url="true"
              hx-indicator="#filter-loading"
            >
              {button.label}
            </a>
        ))}
      </div>
    </div>
  )}

  <!-- VENUE FILTER SECTION -->
  {filterState.venueButtons.length > 0 && (
    <div class="venue-filter">
      <div
        class="venue-filter-buttons"
        role="region"
        tabindex="0"
        aria-label={language === 'no' ? 'Filtrer etter sted' : 'Filter by venue'}
      >
        <a
          href={filterState.allVenuesButton.pageHref}
          rel="nofollow"
          class:list={['link-button', { active: filterState.allVenuesButton.isActive }]}
          aria-pressed={filterState.allVenuesButton.isActive}
          data-filter-type="venue"
          data-filter-value={filterState.allVenuesButton.value}
          hx-get={filterState.allVenuesButton.apiHref}
          hx-target="#event-results"
          hx-swap="innerHTML show:none"
          hx-push-url="true"
          hx-indicator="#filter-loading"
        >
          {filterState.allVenuesButton.label}
        </a>

        {filterState.venueButtons.map((button) => {
          return (
            <a
              href={button.pageHref}
              rel="nofollow"
              class:list={['link-button', { active: button.isActive }]}
              aria-pressed={button.isActive}
              data-filter-type="venue"
              data-filter-value={button.value}
              hx-get={button.apiHref}
              hx-target="#event-results"
              hx-swap="innerHTML show:none"
              hx-push-url="true"
              hx-indicator="#filter-loading"
            >
              {button.label}
            </a>
          );
        })}
      </div>
    </div>
  )}

</section>

<!-- Loading indicator for htmx requests (targeted via hx-indicator="#filter-loading") -->
<div id="filter-loading" aria-live="polite" aria-busy="false">
  {language === 'no' ? 'Laster arrangementer...' : 'Loading events...'}
</div>

<script>
  import { initProgramFilterDragScroll } from '../scripts/programFilterDragScroll.js';

  initProgramFilterDragScroll();
</script>

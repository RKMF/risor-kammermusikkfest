---
import { detectLanguage, type Language } from '../lib/utils/language.js';

export interface Props {
  targetDate: string;
  title?: string;
  style?: 'large' | 'compact' | 'minimal';
  completedMessage?: string;
  hideWhenComplete?: boolean;
}

const {
  targetDate: targetDateStr,
  title,
  style = 'compact',
  completedMessage,
  hideWhenComplete = false
} = Astro.props;

const language = detectLanguage(Astro.request);

const STRINGS: Record<Language, {
  completedMessage: string;
  ariaPrefix: string;
  ariaSuffix: string;
  conjunction: string;
  day: [string, string];
  hour: [string, string];
  minute: [string, string];
}> = {
  no: {
    completedMessage: 'Tiden er ute!',
    ariaPrefix: 'Nedtelling:',
    ariaSuffix: 'igjen',
    conjunction: 'og',
    day: ['dag', 'dager'],
    hour: ['time', 'timer'],
    minute: ['minutt', 'minutter']
  },
  en: {
    completedMessage: 'Time is up!',
    ariaPrefix: 'Countdown:',
    ariaSuffix: 'remaining',
    conjunction: 'and',
    day: ['day', 'days'],
    hour: ['hour', 'hours'],
    minute: ['minute', 'minutes']
  }
};

const strings = STRINGS[language];
const resolvedCompletedMessage = completedMessage || strings.completedMessage;

// Calculate time remaining server-side for initial render
function getTimeRemaining(targetDate: Date) {
  const now = new Date();
  const diff = targetDate.getTime() - now.getTime();

  if (diff <= 0) {
    return { expired: true, days: 0, hours: 0, minutes: 0 };
  }

  const days = Math.floor(diff / (1000 * 60 * 60 * 24));
  const hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
  const minutes = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));

  return { days, hours, minutes, expired: false };
}

// Default time remaining
let timeRemaining = { expired: true, days: 0, hours: 0, minutes: 0 };
let updateInterval = '60s';
let visibleParts: Array<{ value: number; label: string }> = [];

// Parse the target date (ISO datetime string from Sanity)
if (targetDateStr) {
  const targetDate = new Date(targetDateStr);
  timeRemaining = getTimeRemaining(targetDate);

  // Determine update frequency based on time remaining
  updateInterval = timeRemaining.days > 1
    ? '3600s' // Update every hour when > 1 day
    : '60s';   // Update every minute when < 1 day
}

visibleParts = [
  timeRemaining.days > 0 ? { value: timeRemaining.days, label: timeRemaining.days === 1 ? strings.day[0] : strings.day[1] } : null,
  timeRemaining.hours > 0 ? { value: timeRemaining.hours, label: timeRemaining.hours === 1 ? strings.hour[0] : strings.hour[1] } : null,
  timeRemaining.minutes > 0 ? { value: timeRemaining.minutes, label: timeRemaining.minutes === 1 ? strings.minute[0] : strings.minute[1] } : null,
].filter((part): part is { value: number; label: string } => part !== null);

const ariaParts = visibleParts.map((part) => `${part.value} ${part.label}`);
const ariaLabel = timeRemaining.expired
  ? resolvedCompletedMessage
  : `${strings.ariaPrefix} ${ariaParts.join(', ')} ${strings.ariaSuffix}`;

// Don't render if expired and hideWhenComplete is true
if (timeRemaining.expired && hideWhenComplete) {
  return null;
}
---

<section class={`countdown countdown--${style}`}>
  <div
    class="countdown__display"
    role={timeRemaining.expired ? "status" : "timer"}
    aria-live="polite"
    aria-atomic="true"
    aria-label={ariaLabel}
  >
    {timeRemaining.expired ? (
      <p class="countdown__expired">
        {resolvedCompletedMessage}
      </p>
    ) : (
      <>
        {title && <p class="countdown__title">{title}</p>}
        <p class="countdown__timer">
          {visibleParts.map((part, index) => (
            <Fragment>
              <span class="countdown__number">{part.value}</span><span class="countdown__label">{` ${part.label}`}</span>{index < visibleParts.length - 2 && <span class="countdown__separator">, </span>}{index === visibleParts.length - 2 && <span class="countdown__separator">{` ${strings.conjunction} `}</span>}
            </Fragment>
          ))}
        </p>
      </>
    )}
  </div>
</section>

<style>
  .countdown {
    text-align: center;
    background-color: var(--color-green-100);
    padding-block: clamp(0.875rem, 2.5vw, 1.5rem);
    padding-inline: clamp(0.875rem, 3vw, 2rem);
    max-width: 60ch;
    margin-inline: auto;
    color: var(--color-green-800);
  }

  .countdown__display {
    position: relative;
  }

  .countdown__title {
    margin: 0 0 var(--space-xs) 0;
    font-size: clamp(var(--step-1), 4vw, var(--step-3));
    font-weight: 400;
    line-height: 1.2;
  }

  .countdown__timer {
    margin: 0;
    font-size: clamp(var(--step-1), 4.5vw, var(--step-3));
    line-height: 1.3;
  }

  .countdown__number {
    font-weight: 700;
  }

  .countdown__label {
    font-weight: 400;
  }

  .countdown__separator {
    font-weight: 400;
  }

  /* Style variations */
  .countdown--large .countdown__title {
    font-size: clamp(var(--step-2), 4.5vw, var(--step-3));
  }

  .countdown--large .countdown__timer {
    font-size: clamp(var(--step-2), 5vw, var(--step-4));
  }

  .countdown--minimal .countdown__title {
    font-size: clamp(var(--step-0), 3vw, var(--step-1));
  }

  .countdown--minimal .countdown__timer {
    font-size: clamp(var(--step-1), 3.5vw, var(--step-2));
  }

  .countdown__expired {
    margin: 0;
    font-size: var(--step-2);
    font-weight: 600;
  }
</style>

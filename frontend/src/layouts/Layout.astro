---
import { sanityClient } from "../lib/sanity/client";
import Analytics from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';
import Menu from '../components/Menu.astro';
import type { MenuItem } from '../components/Menu.astro';
import Footer from '../components/Footer.astro';
import type { SiteSettings } from '../components/Footer.astro';
import HreflangTags from '../components/HreflangTags.astro';
import SEO from '../components/SEO.astro';
import OrganizationSchema from '../components/structured-data/OrganizationSchema.astro';
import { detectLanguage, type Language } from '../lib/utils/language.js';
import { QueryBuilder } from '../lib/sanity/queryBuilder.js';

// Fonts and tokens need to load before the rest of the site styles.
import '../styles/reset.css';
import '../styles/fonts.css';
import '../styles/tokens.css';
import '../styles/primitives.css';
import '../styles/base.css';
import '../styles/utilities.css';
import '../styles/scroll-containers.css';
import '../styles/scroll-navigation.css';
import '../styles/components.css';
import '../styles/layouts.css';

interface SeoData {
  title?: string;
  description?: string;
  indexingStatus?: 'index' | 'noindex';
}

export interface Props {
  title: string;
  description?: string;
  slugNo?: string;
  slugEn?: string;
  frontpage?: boolean;
  /** SEO data from Sanity CMS */
  seo?: SeoData;
  /** Image for Open Graph/Twitter cards (Sanity image object) */
  image?: any;
  /** Page type for OG (website, article, event) */
  ogType?: 'website' | 'article' | 'event';
  /** Published date for articles */
  publishedDate?: string;
  /** Modified date */
  modifiedDate?: string;
}

const {
  title,
  description = "Norges ledende kammermusikkfestival i Risør",
  slugNo,
  slugEn,
  frontpage = false,
  seo,
  image,
  ogType = 'website',
  publishedDate,
  modifiedDate,
} = Astro.props;

const currentLang: Language = detectLanguage(Astro.request);
const currentPath = new URL(Astro.request.url).pathname;

const { query: menuQuery, params: menuParams } = QueryBuilder.siteSettingsMenu();
const menuData = await sanityClient.fetch<{ menuItems: MenuItem[]; symbolLogo?: { name: string; image: any } }>(menuQuery, menuParams);
const menuItems = menuData?.menuItems || [];
const symbolLogo = menuData?.symbolLogo;

const { query: footerQuery, params: footerParams } = QueryBuilder.siteSettingsFooter();
const siteSettings = await sanityClient.fetch<SiteSettings>(footerQuery, footerParams);
const faviconUrl = siteSettings?.favicon?.asset?.url || '/favicon.svg';
const faviconMimeType = siteSettings?.favicon?.asset?.mimeType || 'image/svg+xml';

---

<!DOCTYPE html>
<html lang={currentLang} id="top">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type={faviconMimeType} href={faviconUrl} />
    <link rel="shortcut icon" href={faviconUrl} />
    <link rel="apple-touch-icon" href={faviconUrl} />
    <meta name="generator" content={Astro.generator} />

    <SEO
      title={title}
      description={description}
      seo={seo}
      image={image}
      lang={currentLang}
      type={ogType}
      publishedDate={publishedDate}
      modifiedDate={modifiedDate}
    />

    <HreflangTags
      currentLang={currentLang}
      currentPath={currentPath}
      slugNo={slugNo}
      slugEn={slugEn}
    />

    <link rel="dns-prefetch" href="//cdn.sanity.io" />
    <link rel="preconnect" href="//cdn.sanity.io" crossorigin />

    <link
      rel="preload"
      href="/fonts/serif/DomaineText-Bold.woff2"
      as="font"
      type="font/woff2"
      crossorigin
      fetchpriority="high"
    />
    <link
      rel="preload"
      href="/fonts/sans-serif/AkkRg_Pro.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />

    <script is:inline>
      window.webAnalyticsBeforeSend = function(event) {
        if (localStorage.getItem('va-disable') === 'true') {
          return null;
        }
        return event;
      };
    </script>

    <Analytics />

    <meta name="htmx-config" content='{"allowEval":false,"allowScriptTags":false}' />
    <script is:inline src="/vendor/htmx.min.js" defer></script>

    <style>
      body {
        display: grid;
        grid-template-rows: auto 1fr auto;
        grid-template-columns: 100%;
        min-block-size: var(--viewport-full);
      }

      .main-content {
        display: flex;
        flex-direction: column;
        width: min(100ch, 100% - 3rem);
        margin-inline: auto;
        margin-block-start: var(--page-top-spacing);
        margin-block-end: calc(var(--space-3xl) * 2);
        container-type: inline-size;
        container-name: content;
      }

      @media (min-width: 768px) {
        .main-content--frontpage {
          margin-block-start: calc(var(--page-top-spacing) * 0.75);
        }
      }

      @media print {
        header,
        nav,
        [role="navigation"],
        .no-print {
          display: none !important;
        }

        body {
          display: block;
          min-block-size: auto;
        }

        .main-content {
          padding: 0;
        }

        * {
          color: #000 !important;
          background: #fff !important;
        }

        article,
        section,
        .event-card,
        .card {
          page-break-inside: avoid;
          break-inside: avoid;
        }

        h1, h2 {
          page-break-after: avoid;
          break-after: avoid;
        }

        body {
          font-size: 12pt;
          line-height: 1.5;
        }

        a[href]::after {
          content: " (" attr(href) ")";
          font-size: 0.8em;
        }

        a[href^="#"]::after,
        a[href^="/"]::after {
          content: "";
        }
      }

      @media (prefers-reduced-motion: reduce) {
        *,
        *::before,
        *::after {
          animation-duration: 0.01ms !important;
          animation-iteration-count: 1 !important;
          transition-duration: 0.01ms !important;
          scroll-behavior: auto !important;
        }
      }

      @media (prefers-contrast: high) {
        body {
          font-weight: var(--font-weight-medium);
        }

        a,
        button {
          font-weight: var(--font-weight-bold);
        }

        *:focus-visible {
          outline-width: 3px !important;
          outline-offset: 3px !important;
        }
      }

      @media (prefers-color-scheme: dark) {
      }
      .skip-link {
        position: absolute;
        top: -100%;
        left: 0;
        background: var(--color-blue);
        color: white;
        padding: var(--space-2) var(--space-4);
        text-decoration: none;
        font-weight: var(--font-weight-bold);
        z-index: 9999;
        border-radius: 0 0 var(--radius-sm) 0;
        opacity: 0;
        transition: top 0.2s ease, opacity 0.2s ease;
      }

      .skip-link:focus {
        top: 0;
        opacity: 1;
      }
    </style>

  </head>
  <body data-last-update={new Date().toISOString()}>
    <a href="#main-content" class="skip-link">
      {currentLang === 'no' ? 'Hopp til hovedinnhold' : 'Skip to main content'}
    </a>

    <Menu
      currentLang={currentLang}
      currentPath={currentPath}
      slugNo={slugNo}
      slugEn={slugEn}
      menuItems={menuItems}
      symbolLogo={symbolLogo}
    />

    <main id="main-content" class:list={['main-content', { 'main-content--frontpage': frontpage }]} tabindex="-1">
      <slot />
    </main>

    <div class="back-to-top-container">
      <a href="#top" class="back-to-top-link">
        <span class="back-to-top-text">{currentLang === 'no' ? 'Tilbake til toppen' : 'Back to the top'} ↑</span>
      </a>
    </div>

    {/* Hide sponsor acknowledgment on frontpage and sponsors page */}
    {!Astro.url.pathname.match(/^\/(sponsorer|en\/sponsors|en)?\/?$/) && (
      <div class="sponsor-acknowledgment">
        <p class="sponsor-acknowledgment-title">
          {currentLang === 'no' ? 'Takk til alle våre sponsorer!' : 'Thank you to all our sponsors!'}
        </p>
        <a href={currentLang === 'no' ? '/sponsorer' : '/en/sponsors'} class="sponsor-acknowledgment-link">
          <span class="sponsor-acknowledgment-text">
            {currentLang === 'no' ? 'Se full oversikt her →' : 'See full overview here →'}
          </span>
        </a>
      </div>
    )}

    <Footer currentLang={currentLang} siteSettings={siteSettings} />

    <OrganizationSchema />

    <script src="../scripts/bfcacheHandler.js"></script>
    <script src="../scripts/ticketTracking.js"></script>

    <script>
      import { initScrollNavigation } from '../scripts/scrollNavigation.js';
      initScrollNavigation();
    </script>

    <SpeedInsights />
  </body>
</html>

<style>
  .back-to-top-container {
    margin-block-start: var(--space-l);
    margin-block-end: var(--space-3xl);
    text-align: center;
  }

  .back-to-top-link {
    display: inline-block;
    text-decoration: none;
    background-image: none;
    font-size: var(--step-1);
    font-weight: var(--font-weight-medium);
  }

  .back-to-top-text {
    position: relative;
  }

  .back-to-top-text::after {
    content: '';
    position: absolute;
    inset-inline-start: 0;
    inset-block-end: 0;
    inline-size: 100%;
    block-size: 0.08em;
    background-color: currentColor;
    transform: scaleX(0);
    transform-origin: right;
    transition: transform var(--transition-fast);
  }

  @media (hover: hover) {
    .back-to-top-link:hover .back-to-top-text::after {
      transform: scaleX(1);
      transform-origin: left;
    }
  }

  .back-to-top-link:focus-visible .back-to-top-text::after {
    transform: scaleX(1);
    transform-origin: left;
  }

  /* Accessibility: Disable smooth scroll for reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .back-to-top-link {
      scroll-behavior: auto;
    }
  }

  /* Print styles - hide back to top link */
  @media print {
    .back-to-top-container {
      display: none !important;
    }
  }

  /* ============================================
     SPONSOR ACKNOWLEDGMENT
     ============================================

     Global sponsor thank-you section.
     Appears after back-to-top, before footer on all pages.
  */

  .sponsor-acknowledgment {
    text-align: center;
    margin-block-end: var(--space-3xl);
  }

  .sponsor-acknowledgment-title {
    font-weight: var(--font-weight-bold);
    font-size: var(--step-1);
    margin-block-end: var(--space-xs);
  }

  .sponsor-acknowledgment-link {
    display: inline-block;
    text-decoration: none;
    background-image: none;
    font-size: var(--step-1);
  }

  .sponsor-acknowledgment-text {
    position: relative;
  }

  .sponsor-acknowledgment-text::after {
    content: '';
    position: absolute;
    inset-inline-start: 0;
    inset-block-end: 0;
    inline-size: 100%;
    block-size: 0.08em;
    background-color: currentColor;
    transform: scaleX(0);
    transform-origin: right;
    transition: transform var(--transition-fast);
  }

  @media (hover: hover) {
    .sponsor-acknowledgment-link:hover .sponsor-acknowledgment-text::after {
      transform: scaleX(1);
      transform-origin: left;
    }
  }

  .sponsor-acknowledgment-link:focus-visible .sponsor-acknowledgment-text::after {
    transform: scaleX(1);
    transform-origin: left;
  }

  @media print {
    .sponsor-acknowledgment {
      display: none !important;
    }
  }
</style>

---
const content = {
  title: '404 - Side ikke funnet',
  heading: 'Side ikke funnet',
  message:
    'Beklager, vi finner ikke siden du leter etter. Siden kan ha blitt flyttet eller slettet. Sjekk at URL-en er riktig, eller gå tilbake til forsiden.',
  eyebrow: 'Risør Kammermusikkfest',
  homeLink: 'Gå til forsiden',
  programLink: 'Se programmet',
  artistsLink: 'Utforsk artistene',
  homeHref: '/',
  programHref: '/program',
  artistsHref: '/artister',
};
---

<!doctype html>
<html lang="no">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{content.title}</title>
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <style>
      @font-face {
        font-family: 'DomaineText';
        src: url('/fonts/serif/DomaineText-Regular.woff2') format('woff2');
        font-display: swap;
      }

      @font-face {
        font-family: 'Akkurat';
        src: url('/fonts/sans-serif/AkkRg_Pro.woff2') format('woff2');
        font-display: swap;
      }

      @font-face {
        font-family: 'Akkurat';
        src: url('/fonts/sans-serif/AkkBd_Pro.woff2') format('woff2');
        font-weight: 700;
        font-display: swap;
      }
    </style>
    <style>
      :root {
        color-scheme: light;
        --bg: #f4f2eb;
        --surface: rgba(255, 255, 255, 0.88);
        --surface-strong: #ffffff;
        --text: #111111;
        --muted: #4f4f4f;
        --accent: #1b198f;
        --accent-soft: #dfe4ff;
        --accent-faint: rgba(27, 25, 143, 0.1);
        --border: rgba(17, 17, 17, 0.1);
        --shadow: 0 22px 48px rgba(27, 25, 143, 0.08);
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 24px;
        font-family: 'Akkurat', system-ui, sans-serif;
        background: var(--bg);
        color: var(--text);
        background-image:
          radial-gradient(circle at top left, rgba(27, 25, 143, 0.12), transparent 26rem),
          linear-gradient(180deg, rgba(255, 255, 255, 0.65), rgba(255, 255, 255, 0.2));
      }

      main {
        width: min(760px, 100%);
        padding: clamp(28px, 5vw, 44px);
        background: var(--surface);
        border: 1px solid var(--border);
        box-shadow: var(--shadow);
        backdrop-filter: blur(8px);
      }

      .eyebrow {
        margin: 0;
        color: var(--accent);
        font-size: 0.875rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      .status {
        margin: 20px 0 0;
        display: inline-flex;
        align-items: baseline;
        gap: 12px;
      }

      .status-code {
        font-family: 'DomaineText', Georgia, serif;
        font-size: clamp(3.8rem, 12vw, 7rem);
        line-height: 1;
        color: var(--accent);
      }

      .status-copy {
        max-width: 15ch;
      }

      h1 {
        margin: 0;
        font-family: 'DomaineText', Georgia, serif;
        font-size: clamp(1.8rem, 4vw, 2.8rem);
        font-weight: 400;
        line-height: 1.05;
      }

      .lede {
        margin: 18px 0 0;
        max-width: 58ch;
        color: var(--muted);
        line-height: 1.65;
        font-size: 1rem;
      }

      .panel {
        margin-top: 28px;
        padding: 18px;
        background: var(--surface-strong);
        border: 1px solid var(--border);
      }

      .panel-title {
        margin: 0;
        font-size: 0.95rem;
        font-weight: 700;
      }

      .panel-text {
        margin: 10px 0 0;
        color: var(--muted);
        line-height: 1.6;
      }

      nav {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        margin-top: 24px;
      }

      a {
        display: inline-block;
        padding: 13px 18px;
        text-decoration: none;
        color: var(--text);
        background: var(--accent-soft);
        border: 1px solid transparent;
        transition: background-color 0.2s ease, border-color 0.2s ease, transform 0.2s ease;
      }

      a:first-child {
        color: #fff;
        background: var(--accent);
      }

      a:hover,
      a:focus-visible {
        border-color: var(--accent);
        transform: translateY(-1px);
      }

      .text-link {
        margin-top: 18px;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 0;
        background: transparent;
        color: var(--accent);
        border: 0;
      }

      .text-link:hover,
      .text-link:focus-visible {
        transform: none;
      }

      @media (max-width: 640px) {
        .status {
          flex-direction: column;
          gap: 8px;
        }

        nav {
          flex-direction: column;
        }

        nav a {
          width: 100%;
          text-align: center;
        }
      }
    </style>
  </head>
  <body>
    <main>
      <p class="eyebrow">{content.eyebrow}</p>
      <div class="status">
        <div class="status-code">404</div>
        <div class="status-copy">
          <h1>{content.heading}</h1>
        </div>
      </div>
      <p class="lede">{content.message}</p>
      <section class="panel" aria-labelledby="help-title">
        <h2 class="panel-title" id="help-title">Prøv en trygg snarvei</h2>
        <p class="panel-text">
          Mange eldre lenker peker nå til nytt program- eller artistsider. Hvis du kom hit fra et gammelt bokmerke,
          er programmet og artistoversikten de beste stedene å starte.
        </p>
      </section>
      <nav>
        <a href={content.homeHref}>{content.homeLink}</a>
        <a href={content.programHref}>{content.programLink}</a>
        <a href={content.artistsHref}>{content.artistsLink}</a>
      </nav>
      <a class="text-link" href="/">Tilbake til festivalforsiden</a>
    </main>
  </body>
</html>

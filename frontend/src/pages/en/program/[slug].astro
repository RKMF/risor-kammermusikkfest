---
export const prerender = false;

import EventDetailContent from '../../../components/EventDetailContent.astro';
import { createDataService } from '../../../lib/sanity/dataService.js';
import { InputValidator } from '../../../lib/security.js';

const slug = InputValidator.validateSlug(Astro.params.slug ?? null);
if (!slug) {
  return new Response(null, { status: 404 });
}

const dataService = createDataService(Astro.request);
let event = null;

try {
  const hasEventSlug = await dataService.hasEventSlug(slug);
  if (!hasEventSlug) {
    return new Response(null, { status: 404 });
  }

  event = await dataService.getEventBySlug(slug);
} catch (error) {
  console.error(`Error loading event "${slug}":`, error);
}

if (!event) {
  return new Response(null, { status: 404 });
}
---

<EventDetailContent event={event} language="en" />

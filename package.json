{
  "name": "risor-kammermusikkfest",
  "private": true,
  "packageManager": "npm@11.12.1",
  "engines": {
    "node": "22.x",
    "npm": ">=11.10.0"
  },
  "workspaces": [
    "studio",
    "frontend"
  ],
  "scripts": {
    "prepare": "node ./scripts/setup-git-hooks.mjs",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:studio": "cd studio && npm run dev",
    "build": "npm run build --workspace=frontend && npm run build --workspace=studio",
    "test": "npm run test --workspaces --if-present",
    "test:watch": "npm run test:watch --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "clean": "npm run clean --workspaces --if-present",
    "check-deps": "npm ls 2>&1 | grep -i 'peer dep\\|UNMET' || echo 'All peer deps satisfied'",
    "check-deps:root": "npm ls --workspaces=false 2>&1 | grep -i 'peer dep\\|UNMET' || echo 'All peer deps satisfied'",
    "typegen": "npm run typegen --workspace=studio"
  },
  "devDependencies": {
    "vite": "7.3.1"
  },
  "overrides": {
    "sanity": "5.20.0"
  }
}

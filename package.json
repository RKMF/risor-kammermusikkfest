{
  "name": "risor-kammermusikkfest",
  "private": true,
  "packageManager": "npm@11.17.0",
  "engines": {
    "node": ">=24.16.0 <25",
    "npm": ">=11.17.0 <12"
  },
  "workspaces": [
    "studio",
    "frontend"
  ],
  "scripts": {
    "prepare": "node ./scripts/setup-git-hooks.mjs",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:studio": "cd studio && npm run dev",
    "build": "npm run build --workspace=frontend && npm run build --workspace=studio",
    "test": "npm run test --workspaces --if-present",
    "test:watch": "npm run test:watch --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "clean": "npm run clean --workspaces --if-present",
    "check-deps": "npm ls 2>&1 | grep -i 'peer dep\\|UNMET' || echo 'All peer deps satisfied'",
    "check-deps:root": "npm ls --workspaces=false 2>&1 | grep -i 'peer dep\\|UNMET' || echo 'All peer deps satisfied'",
    "outdated:deps": "npm outdated --workspaces",
    "audit:deps": "npm audit --workspaces --omit=dev",
    "audit:deps:ci": "npm audit --workspaces --omit=dev --audit-level=high",
    "typegen": "npm run typegen --workspace=studio"
  },
  "devDependencies": {
    "vite": "7.3.5"
  },
  "overrides": {
    "sanity": "6.0.0",
    "path-to-regexp": "6.3.0",
    "rollup": "4.61.1",
    "anymatch@3.1.3": {
      "picomatch": "2.3.2"
    }
  },
  "allowScripts": {
    "@lezer/javascript": true,
    "esbuild": true,
    "sharp": true
  }
}
